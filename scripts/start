#!/usr/bin/env bash
if tmux has-session -t vm 2>/dev/null; then
  echo "Session 'vm' already exists. Use attach-start to resume it."
  exit 1
fi
tmux new-session -d -s vm
tmux split-window -v -t vm
tmux send-keys -t vm:0.1 'journalctl -fu ollama' Enter
tmux split-window -h -t vm:0.1
tmux send-keys -t vm:0.2 'watch -n1 nvidia-smi' Enter
tmux select-pane -t vm:0.1
tmux resize-pane -t vm:0.1 -y 30
tmux select-pane -t vm:0.0
tmux attach-session -t vm
